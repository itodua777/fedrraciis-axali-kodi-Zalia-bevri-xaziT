model Branch {
  id           String       @id @default(uuid())
  name         String
  companyId    String
  company      Company      @relation(fields: [companyId], references: [id])
  country      String?
  legalAddress String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  departments  Department[]
  users        User[]
}
