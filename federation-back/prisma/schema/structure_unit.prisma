model StructureUnit {
  id              String          @id @default(uuid())
  companyId       String
  name            String
  unitType        String
  compositionType String?
  termDuration    String?
  actNumber       String?
  issueDate       String?
  parentId        String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  parent          StructureUnit?  @relation("SubUnits", fields: [parentId], references: [id], onDelete: Cascade)
  children        StructureUnit[] @relation("SubUnits")
  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users           User[]
  permissions     RolePermission[]
}
