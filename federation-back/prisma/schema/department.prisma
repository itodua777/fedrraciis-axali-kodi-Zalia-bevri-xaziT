model Department {
  id        String   @id @default(uuid())
  name      String
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id])
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  roles     Role[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
